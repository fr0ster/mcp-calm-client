# ─── Copy to .env (git-ignored) and fill in before running integration tests ─

# Mode: "oauth2" (live tenant) or "sandbox" (SAP API Business Hub).
# If unset, tests are skipped with a clear message.
CALM_MODE=

# ─── OAuth2 mode (when CALM_MODE=oauth2) ────────────────────────────────────
# Tenant host for the Cloud ALM APIs.
#   Pattern:  https://<tenant>.<region>.alm.cloud.sap
#   Regions:  eu10, eu20, us10, ap10, jp10, ca10, eu11, cn20
CALM_BASE_URL=

# XSUAA OAuth2 client_credentials — copy from your service key JSON:
#   "uaa": { "url": …, "clientid": …, "clientsecret": … }
CALM_UAA_URL=
CALM_UAA_CLIENT_ID=
CALM_UAA_CLIENT_SECRET=

# ─── Sandbox mode (when CALM_MODE=sandbox) ──────────────────────────────────
# Default base URL for sandbox — uncomment only to override.
# CALM_BASE_URL=https://sandbox.api.sap.com/SAPCALM

# API key from https://api.sap.com/ → log in → SAPCALM API → Show API Key.
CALM_API_KEY=

# ─── Optional per-service fixtures (tests that need them self-skip if unset) ─
# A project in your tenant/sandbox safe to read and (with CALM_DESTRUCTIVE=1)
# to write to. Dedicated test project strongly recommended for destructive
# operations — do not point at real production work.
CALM_TEST_PROJECT_ID=
CALM_TEST_FEATURE_UUID=
CALM_TEST_FEATURE_DISPLAY_ID=
CALM_TEST_DOCUMENT_UUID=
CALM_TEST_TASK_ID=
CALM_TEST_TEST_CASE_UUID=
CALM_TEST_HIERARCHY_NODE_UUID=
CALM_TEST_ANALYTICS_PROVIDER=Tasks
CALM_TEST_LOG_PROVIDER=
CALM_TEST_LOG_SERVICE_ID=

# ─── Gates ──────────────────────────────────────────────────────────────────
# Set to "1" to enable destructive tests (create/update/delete). Off by
# default — safer to run read-only first.
CALM_DESTRUCTIVE=0

# Optional override for HTTP timeout (ms). Default 30000.
# CALM_TIMEOUT=60000
